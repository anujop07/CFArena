# ─── Exclude heavy folders from Docker build context ────────────────────────────
# node_modules is ~200MB+. Docker rebuilds it from package.json inside the container.
node_modules

# dist is regenerated by `npm run build` inside the container
dist

# Git history — not needed in Docker
.git
.gitignore
.gitattributes

# Environment files — secrets never go in Docker build context
# (Removed .env so Vite can bake the API URL into the frontend build)
*.local

# Editor / OS
.vscode
.idea
.DS_Store
Thumbs.db

# Documentation
README.md
*.md

# Nginx config is copied explicitly in Dockerfile — exclude from catch-all
# (Actually we DO need nginx.conf — do not exclude it)
